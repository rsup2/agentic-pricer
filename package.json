{
  "name": "agentic-pricer-shadow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shadow agentic pricer — Mastra app that prices live traffic in parallel to the main engine and persists results to Snowflake keyed by requestId.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "mastra dev",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "smoke": "tsx scripts/smoke.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@mastra/core": "^1.42.0",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "snowflake-sdk": "^2.4.3",
    "p-limit": "^6.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "mastra": "^1.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0"
  }
}
