{
  "name": "agentic-pricer-shadow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shadow agentic pricer — Mastra app that prices live traffic in parallel to the main engine and persists results to Snowflake keyed by requestId.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "mastra dev",
    "build": "tsc -p tsconfig.json",
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "prestart:local": "npm run build",
    "start:local": "node --env-file=.env dist/index.js",
    "smoke": "tsx --env-file=.env scripts/smoke.ts",
    "probe:group": "tsx --env-file=.env scripts/probe-group.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^0.19.10",
    "@mastra/core": "^1.42.0",
    "hono": "^4.6.14",
    "p-limit": "^6.1.0",
    "snowflake-sdk": "^2.4.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "mastra": "^1.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
